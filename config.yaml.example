# SSE Streaming Chat Configuration File
# This file demonstrates configuration via YAML
# You can also use environment variables (see .env.example)

server:
  port: "8080"
  host: "localhost"
  read_timeout: 15    # seconds
  write_timeout: 15   # seconds
  idle_timeout: 60    # seconds

openai:
  api_key: ""                    # Set via SSE_OPENAI_API_KEY env var
  model: "gpt-3.5-turbo"
  base_url: ""                   # Optional: for Azure OpenAI or proxies
  max_tokens: 1000
  temperature: 0.7

grok:
  api_key: ""                    # Set via SSE_GROK_API_KEY env var
  model: "grok-beta"
  base_url: "https://api.x.ai/v1"
  max_tokens: 1000
  temperature: 0.7

app:
  default_provider: "openai"     # "openai" or "grok"
  streaming_delay: 50            # milliseconds between tokens (for demo)
  max_connections: 100           # maximum concurrent SSE connections
  log_level: "info"              # "debug", "info", "warn", "error"